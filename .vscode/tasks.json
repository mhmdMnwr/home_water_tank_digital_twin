{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "PlatformIO: Build (venv)",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/platformio run",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "PlatformIO: Upload (venv)",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/platformio run --target upload --upload-port /dev/ttyUSB0",
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
